{
	"$id": "https://schemas.lbrunner.net/growler/config.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"description": "Config file for growler, a personal Homebrew wrapper that tracks installed packages and pinned versions per group.",
	"properties": {
		"packages": {
			"additionalProperties": {
				"additionalProperties": { "type": "string" },
				"description": "Package name to pinned version (or \"latest\")",
				"type": "object"
			},
			"description": "Package groups, e.g. [packages.required] or [packages.optional]",
			"type": "object"
		}
	},
	"title": "growler.toml",
	"type": "object"
}
